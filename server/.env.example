# ── MySQL ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=1
DB_NAME=chaebol_db

# ── 공공데이터포털 (data.go.kr) ─────────────────
# 발급: https://www.data.go.kr → 마이페이지 → 인증키 신청
KFTC_API_KEY=your_data_go_kr_api_key_here

# ── 금융감독원 DART ─────────────────────────────
# 발급: https://opendart.fss.or.kr → Open DART → 인증키 신청
DART_API_KEY=your_dart_api_key_here

# ── AWS Bedrock ─────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ── 서버 ────────────────────────────────────────
PORT=3001
